
{
  "entities": {
    "Clinic": {
      "title": "Clinic",
      "description": "A healthcare facility registered in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the clinic" },
        "slug": { "type": "string", "description": "Unique URL-friendly identifier" },
        "timezone": { "type": "string", "default": "Asia/Kolkata" },
        "ownerEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "ownerEmail"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "A medical professional working at a clinic.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "clinicId": { "type": "string" },
        "specialization": { "type": "string" },
        "avgConsultMinutes": { "type": "number", "default": 12 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "clinicId"]
    },
    "ApprovedReceptionist": {
      "title": "Approved Receptionist",
      "description": "An email address pre-approved to act as a receptionist for a clinic.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "clinicId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "clinicId"]
    },
    "DailyCode": {
      "title": "Daily Code",
      "description": "A rotating access code for patients, unique per clinic per day.",
      "type": "object",
      "properties": {
        "clinicId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clinicId", "date", "code"]
    },
    "Token": {
      "title": "Token",
      "description": "A patient's position in the queue.",
      "type": "object",
      "properties": {
        "clinicId": { "type": "string" },
        "doctorId": { "type": "string" },
        "tokenNumber": { "type": "number" },
        "patientName": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "serving", "done", "skipped"] },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "createdAt": { "type": "string", "format": "date-time" },
        "calledAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clinicId", "doctorId", "tokenNumber", "patientName", "status", "date"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/clinics/{clinicId}": {
      "schema": "Clinic",
      "description": "Store clinic metadata"
    },
    "/clinics/{clinicId}/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctors belonging to a clinic"
    },
    "/clinics/{clinicId}/approved_receptionists/{email}": {
      "schema": "ApprovedReceptionist",
      "description": "Allowlist for receptionist login"
    },
    "/dailyCodes/{codeId}": {
      "schema": "DailyCode",
      "description": "Rotating patient codes (ID is clinicId_date)"
    },
    "/tokens/{tokenId}": {
      "schema": "Token",
      "description": "Queue tokens across all clinics"
    }
  }
}
